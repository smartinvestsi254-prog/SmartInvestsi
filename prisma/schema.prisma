// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider  = "prisma-client-js"
  engineType = "binary"  // v7: explicit for serverless compat
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  name                String?
  role                Role           @default(USER)
  termsAcceptedAt     DateTime?
  emailVerifiedAt     DateTime?
  failedLoginAttempts Int            @default(0)
  isBanned            Boolean        @default(false)
  twoFactorSecret     String?
  lastFailedLogin     DateTime?
  subscriptionTier    String?        @default("FREE")
  accounts            BankAccount[]
  assets              AssetHolding[]
  transactions        Transaction[]
  subscriptions       Subscription[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  payments            Payment[]

  @@index([email])
  @@index([isBanned])
}

model BankAccount {
  id               String    @id @default(cuid())
  accountId        String    @unique // SI-ACCT-XXXXX
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String // checking/savings/investment
  currency         String
  balance          Float     @default(0)
  availableBalance Float     @default(0)
  status           String    @default("active") // active/frozen/closed
  kycLevel         String    @default("basic")
  transactionPin   String? // hashed
  pinAttempts      Int       @default(0)
  pinLockedUntil   DateTime?
  holds            Json[]
  createdAt        DateTime  @default(now())
  lastActivity     DateTime  @updatedAt

  transactions Transaction[]
  payments     Payment[]

  @@index([userId])
}

model Payment {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])

  transactionId String?      @unique
  transaction   Transaction? @relation("PaymentTransaction", fields: [transactionId], references: [id])

  checkoutRequestId String    @unique
  mpesaReceipt      String?   @unique
  amount            Float
  currency          String    @default("KES")
  phoneNumber       String
  tillNumber        String    @default("5263811")
  shortcode         String    @default("8038267")
  status            String    @default("pending")
  subscriptionType  String?
  reference         String?
  callbackData      Json?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  @@index([userId])
  @@index([status])
  @@index([checkoutRequestId])
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               String // PREMIUM | ENTERPRISE
  status             String    @default("active") // active | cancelled | expired | pending
  startDate          DateTime  @default(now())
  endDate            DateTime?
  nextBillingDate    DateTime?
  paymentMethod      String? // mpesa | paypal | stripe | crypto
  autoRenew          Boolean   @default(false)
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  cancelledAt        DateTime?

  @@unique([userId, plan])
  @@index([userId])
  @@index([status])
  @@index([nextBillingDate])
}

model Transaction {
  id            String @id @default(cuid())
  transactionId String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id])

  fromAccountId String?
  toAccountId   String?

  amount       Float
  currency     String
  description  String
  status       String
  fee          Float?
  pinVerified  Boolean   @default(false)
  autoApproved Boolean   @default(false)
  reference    String
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])

  payment Payment? @relation("PaymentTransaction")
}

model AssetHolding {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetType String // cash/crypto
  symbol    String // USD/BTC/ETH
  quantity  Float
  valueUSD  Float // current value
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, symbol])
  @@index([userId])
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  riskTolerance   String   @default("MODERATE") // CONSERVATIVE | MODERATE | AGGRESSIVE
  investmentGoals Json?    // ["growth", "income", "preservation"]
  preferences     Json?    // { "crypto": true, "stocks": false, "notification_freq": "daily" }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  refereeEmail String
  refereeId    String?  // Set after signup
  status       String   @default("PENDING") // PENDING | COMPLETED | REWARDED
  rewardTier   String?  // FREE | PREMIUM | ENTERPRISE
  rewardUsed   Boolean  @default(false)
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  referrer     User     @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referee      User?    @relation("RefereeReferrals", fields: [refereeId], references: [id])

  @@index([referrerId])
  @@index([refereeEmail])
  @@index([status])
}

model SupportTicket {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject        String
  description    String
  status         String   @default("OPEN") // OPEN | ASSIGNED | RESOLVED | CLOSED
  priority       String   @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  adminId        String?  // Assigned admin
  resolutionNotes String?
  npsScore       Int?     // 0-10 feedback
  autoGrantTier  String?  // PREMIUM | ENTERPRISE if granted on resolution
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  resolvedAt     DateTime?
  closedAt       DateTime?

  assignedAdmin  User?    @relation("AdminTickets", fields: [adminId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model Portfolio {
  id              String     @id @default(cuid())
  userEmail       String
  user            User       @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  name            String
  description     String?
  currency        String     @default("USD")
  totalValue      Float      @default(0)
  cashBalance     Float      @default(0)
  targetAllocation Json?
  isActive        Boolean    @default(true)
  isDefault       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  holdings        Holding[]
  transactions    Transaction[]
  performances    PortfolioPerformance[]
  rebalances      Rebalance[]
}

model Holding {
  id                String  @id @default(cuid())
  portfolioId       String
  portfolio         Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  symbol            String
  assetType         String  // STOCK | BOND | CRYPTO | CASH
  quantity          Float
  averageCost       Float
  costBasis         Float
  currentPrice      Float?
  marketValue       Float   @default(0)
  unrealizedGain    Float   @default(0)
  unrealizedGainPct Float   @default(0)
  allocation        Float   @default(0)
  lastPriceUpdate   DateTime?

  @@index([portfolioId])
  @@index([symbol])
}

model PortfolioPerformance {
  id            String   @id @default(cuid())
  portfolioId   String
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  date          DateTime @unique
  totalValue    Float
  cashBalance   Float
  investedAmount Float
  gainLoss      Float
  gainLossPct   Float
  dailyReturn   Float

  @@index([portfolioId])
  @@index([date])
}

model Rebalance {
  id            String   @id @default(cuid())
  portfolioId   String
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  status        String   @default("PROPOSED") // PROPOSED | EXECUTING | COMPLETED
  proposedTrades Json[]
  reason        String?
  executedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([portfolioId])
  @@index([status])
}

// Extend User relations
model User {
  id                  String          @id @default(cuid())
  email               String          @unique
  name                String?
  role                Role            @default(USER)
  termsAcceptedAt     DateTime?
  emailVerifiedAt     DateTime?
  failedLoginAttempts Int             @default(0)
  isBanned            Boolean         @default(false)
  twoFactorSecret     String?
  lastFailedLogin     DateTime?
  subscriptionTier    String?         @default("FREE")
  profile             UserProfile?
  referralsGiven      Referral[]      @relation("ReferrerReferrals")
  referralsReceived   Referral[]      @relation("RefereeReferrals")
  tickets             SupportTicket[]
  portfolios          Portfolio[]
  accounts            BankAccount[]
  assets              AssetHolding[]
  transactions        Transaction[]
  subscriptions       Subscription[]
  assignedTickets     SupportTicket[] @relation("AdminTickets")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  payments            Payment[]

  @@index([email])
  @@index([isBanned])
}

enum Role {
  USER
  ADMIN
}
