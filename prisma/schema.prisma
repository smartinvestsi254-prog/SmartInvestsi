// ===========================================
// GENERATOR & DATASOURCE
// Database: PostgreSQL on Supabase
// ===========================================

generator client {
  provider  = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

// ===========================================
// USER MANAGEMENT
// ===========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  passwordHash  String?  @db.VarChar(255)
  emailVerified Boolean @default(false)
  role      UserRole @default(VIEWER)
  resetToken String?  @unique
  resetExpires DateTime?
  confirmToken String?  @unique
  confirmExpires DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflowsLocked     Workflow[]        @relation("LockedWorkflows")
  workflowEvents      WorkflowEvent[]
  approvals           WorkflowApproval[]
  reportedIncidents   Incident[]        @relation("ReportedIncidents")
  ownedIncidents      Incident[]        @relation("OwnedIncidents")
  profile             UserProfile?
}

enum UserRole {
  ADMIN
  EDITOR
  REVIEWER
  ANALYST
  INCIDENT_COMMANDER
  VIEWER
}

// User Profile for Investment Dashboard Personalization
model UserProfile {
  id                String    @id @default(uuid())
  user              User?     @relation(fields: [userId], references: [id])
  userId            String?   @unique
  email             String    @unique
  investmentGoal    String?   // User's primary investment goal
  timeHorizon       String?   // Investment time horizon (e.g., "short-term", "long-term")
  riskTolerance     String?   // Risk profile (e.g., "conservative", "moderate", "aggressive")
  preferredRegion   String?   // Preferred investment region
  portfolioValue    Float?    // Current portfolio value
  monthlyIncome     Float?    // Monthly income for savings tracking
  preferences       Json?     // Flexible JSON for additional preferences
  premiumAccess     Boolean   @default(false)
  premiumExpiry     DateTime?
  lastUpdated       DateTime  @updatedAt
  createdAt         DateTime  @default(now())
}

// ===========================================
// APPLICATION SETTINGS
// ===========================================

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ===========================================
// WORKFLOW & CONTENT MANAGEMENT
// ===========================================

model ContentItem {
  id        String        @id @default(uuid())
  state     WorkflowState @default(DRAFT)
  version   Int           @default(1)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  workflow Workflow?
}

enum WorkflowState {
  DRAFT
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  PUBLISHED
  ARCHIVED
  REJECTED
}

model Workflow {
  id         String        @id @default(uuid())
  contentId  String        @unique
  state      WorkflowState @default(DRAFT)
  lockedById String?
  lockedAt   DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  content    ContentItem        @relation(fields: [contentId], references: [id])
  lockedBy   User?              @relation("LockedWorkflows", fields: [lockedById], references: [id])
  events     WorkflowEvent[]
  approvals  WorkflowApproval[]
}

model WorkflowEvent {
  id         String        @id @default(uuid())
  workflowId String
  actorId    String
  fromState  WorkflowState
  toState    WorkflowState
  reason     String?
  meta       Json?
  createdAt  DateTime      @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id])
  actor    User     @relation(fields: [actorId], references: [id])
}

model WorkflowApproval {
  id         String   @id @default(uuid())
  workflowId String
  reviewerId String
  decision   String
  notes      String?
  createdAt  DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id])
  reviewer User     @relation(fields: [reviewerId], references: [id])
}

// ===========================================
// INCIDENT MANAGEMENT
// ===========================================

model Incident {
  id           String           @id @default(uuid())
  title        String
  summary      String
  severity     IncidentSeverity
  status       IncidentStatus   @default(OPEN)
  reportedById String
  ownerId      String?
  runbookKey   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  mitigatedAt  DateTime?
  resolvedAt   DateTime?
  closedAt     DateTime?

  reportedBy User            @relation("ReportedIncidents", fields: [reportedById], references: [id])
  owner      User?           @relation("OwnedIncidents", fields: [ownerId], references: [id])
  timeline   IncidentEvent[]
  updates    IncidentUpdate[]
}

enum IncidentSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  MITIGATING
  RESOLVED
  CLOSED
}

model IncidentEvent {
  id         String   @id @default(uuid())
  incidentId String
  message    String
  meta       Json?
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id])
}

model IncidentUpdate {
  id           String         @id @default(uuid())
  incidentId   String
  status       IncidentStatus
  publicNote   String?
  internalNote String?
  createdAt    DateTime       @default(now())

  incident Incident @relation(fields: [incidentId], references: [id])
}

// ===========================================
// PARTNER & DATA LICENSE MANAGEMENT
// ===========================================

model Partner {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  licenses DataLicense[]
}

model DataLicense {
  id                 String            @id @default(uuid())
  partnerId          String
  status             LicenseStatus     @default(ACTIVE)
  allowedPurposes    DataUsagePurpose[]
  attributionRequired Boolean          @default(false)
  attributionText    String?
  allowRedistribution Boolean          @default(false)
  rateLimitPerMin    Int?
  startDate          DateTime?
  endDate            DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  partner            Partner            @relation(fields: [partnerId], references: [id])
  entitlements       DataEntitlement[]
  usageLogs          DataUsageLog[]
}

enum LicenseStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum DataUsagePurpose {
  ANALYTICS
  DISPLAY
  REDISTRIBUTION
  INTERNAL
}

model DataEntitlement {
  id        String   @id @default(uuid())
  licenseId String
  datasetKey String
  createdAt DateTime @default(now())

  license DataLicense @relation(fields: [licenseId], references: [id])
}

model DataUsageLog {
  id          String            @id @default(uuid())
  licenseId   String?
  datasetKey  String
  purpose     DataUsagePurpose
  actorUserId String?
  ip          String?
  userAgent   String?
  requestMeta Json?
  createdAt   DateTime          @default(now())

  license DataLicense? @relation(fields: [licenseId], references: [id])
}

// ===========================================
// DIPLOMACY PORTAL
// ===========================================

model DiplomacyMission {
  id           String        @id @default(uuid())
  name         String
  country      String
  city         String
  region       String?
  type         MissionType
  status       MissionStatus @default(ACTIVE)
  contactEmail String?
  contactPhone String?
  focusArea    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum MissionType {
  EMBASSY
  HIGH_COMMISSION
  CONSULATE
  PERMANENT_MISSION
  HONORARY_CONSULATE
}

enum MissionStatus {
  ACTIVE
  PAUSED
  PLANNING
}

model DiplomacyTreaty {
  id            String       @id @default(uuid())
  title         String
  partner       String
  sector        String
  status        TreatyStatus @default(NEGOTIATION)
  signedAt      DateTime?
  nextMilestone String?
  summary       String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum TreatyStatus {
  NEGOTIATION
  SIGNED
  RATIFIED
  IN_REVIEW
  IMPLEMENTATION
  EXPIRED
}

model DiplomacyDelegation {
  id           String            @id @default(uuid())
  name         String
  focus        String
  hostCity     String
  hostCountry  String
  leadMinistry String
  status       DelegationStatus  @default(PLANNED)
  startDate    DateTime
  endDate      DateTime
  objectives   String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

enum DelegationStatus {
  PLANNED
  CONFIRMED
  COMPLETED
  CANCELLED
}

model DiplomacyDocument {
  id             String            @id @default(uuid())
  title          String
  category       DocumentCategory
  classification DocumentClass     @default(RESTRICTED)
  ownerDept      String
  summary        String?
  linkUrl        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum DocumentCategory {
  BRIEFING_NOTE
  PROTOCOL_GUIDE
  TREATY_DRAFT
  ECONOMIC_DIPLOMACY
  OTHER
}

enum DocumentClass {
  PUBLIC
  RESTRICTED
  CONFIDENTIAL
}

// ===========================================
// TRADING MODELS (MERGED FROM SUPABASE)
// ===========================================

model SubscriptionTier {
  id                String   @id @default(uuid())
  name              String   @unique
  displayName       String
  monthlyPrice      Float
  annualPrice       Float
  description       String?
  features          Json
  limits            Json
  isActive          Boolean  @default(true)
  displayOrder      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscriptions     Subscription[]
  @@map("subscription_tiers")
}

model Subscription {
  id                String           @id @default(uuid())
  userEmail         String
  tierId            String
  status            SubscriptionStatus @default(ACTIVE)
  startDate         DateTime         @default(now())
  endDate           DateTime?
  autoRenew         Boolean          @default(false)
  paymentMethod     String?
  lastPaymentDate   DateTime?
  nextBillingDate   DateTime?
  cancelledAt       DateTime?
  cancelReason      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tier              SubscriptionTier @relation(fields: [tierId], references: [id])
  transactions      SubscriptionTransaction[]

  @@unique([userEmail, status])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIAL
}

model SubscriptionTransaction {
  id              String   @id @default(uuid())
  subscriptionId  String
  amount          Float
  currency        String   @default("USD")
  status          String
  paymentMethod   String
  transactionId   String?
  metadata        Json?
  createdAt       DateTime @default(now())

  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
  @@map("subscription_transactions")
}

model Portfolio {
  id                String   @id @default(uuid())
  userEmail         String
  name              String
  description       String?
  currency          String   @default("USD")
  totalValue        Float    @default(0)
  cashBalance       Float    @default(0)
  isDefault         Boolean  @default(false)
  isActive          Boolean  @default(true)
  targetAllocation  Json?
  rebalanceSettings Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  holdings          Holding[]
  transactions      Transaction[]
  performances      PortfolioPerformance[]
  rebalances        Rebalance[]

  @@index([userEmail])
  @@map("portfolios")
}

model Holding {
  id                String   @id @default(uuid())
  portfolioId       String
  symbol            String
  assetType         AssetType
  quantity          Float
  averageCost       Float
  currentPrice      Float    @default(0)
  marketValue       Float    @default(0)
  costBasis         Float    @default(0)
  unrealizedGain    Float    @default(0)
  unrealizedGainPct Float    @default(0)
  allocation        Float    @default(0)
  lastPriceUpdate   DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  portfolio         Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  dividends         Dividend[]

  @@index([portfolioId, symbol])
  @@map("holdings")
}

enum AssetType {
  STOCK
  ETF
  MUTUAL_FUND
  BOND
  CRYPTO
  REIT
  COMMODITY
  CASH
  OTHER
}

model Transaction {
  id                String          @id @default(uuid())
  portfolioId       String
  symbol            String
  type              TransactionType
  quantity          Float
  price             Float
  fees              Float           @default(0)
  adminFee          Float           @default(0)
  totalAmount       Float
  notes             String?
  executedAt        DateTime        @default(now())
  createdAt         DateTime        @default(now())

  portfolio         Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, executedAt])
  @@map("transactions")
}

enum TransactionType {
  BUY
  SELL
  DIVIDEND
  DEPOSIT
  WITHDRAWAL
  FEE
  TRANSFER_IN
  TRANSFER_OUT
}

model PortfolioPerformance {
  id                String   @id @default(uuid())
  portfolioId       String
  date              DateTime
  totalValue        Float
  cashBalance       Float
  investedAmount    Float
  gainLoss          Float
  gainLossPct       Float
  dailyReturn       Float?
  createdAt         DateTime @default(now())

  portfolio         Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, date])
  @@map("portfolio_performances")
}

model Rebalance {
  id                String          @id @default(uuid())
  portfolioId       String
  status            RebalanceStatus @default(PROPOSED)
  proposedTrades    Json
  executedTrades    Json?
  reason            String?
  proposedAt        DateTime        @default(now())
  executedAt        DateTime?
  createdAt         DateTime        @default(now())

  portfolio         Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  @@map("rebalances")
}

enum RebalanceStatus {
  PROPOSED
  APPROVED
  EXECUTED
  REJECTED
  CANCELLED
}

model Dividend {
  id                String   @id @default(uuid())
  holdingId         String
  symbol            String
  amount            Float
  currency          String   @default("USD")
  exDate            DateTime
  paymentDate       DateTime
  declaredDate      DateTime?
  frequency         String?
  isReinvested      Boolean  @default(false)
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())

  holding           Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)

  @@index([symbol, exDate])
  @@map("dividends")
}

model PriceAlert {
  id                String      @id @default(uuid())
  userEmail         String
  symbol            String
  targetPrice       Float
  condition         AlertCondition
  isActive          Boolean     @default(true)
  isTriggered       Boolean     @default(false)
  notifyEmail       Boolean     @default(true)
  notifySMS         Boolean     @default(false)
  notifyApp         Boolean     @default(true)
  triggeredAt       DateTime?
  triggeredPrice    Float?
  expiresAt         DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  notifications     AlertNotification[]

  @@index([userEmail, isActive])
  @@index([symbol, isActive])
  @@map("price_alerts")
}

enum AlertCondition {
  ABOVE
  BELOW
  CROSSES
  PERCENT_CHANGE
}

model AlertNotification {
  id                String   @id @default(uuid())
  alertId           String
  channel           String
  sentAt            DateTime @default(now())
  status            String
  errorMessage      String?

  alert             PriceAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  @@map("alert_notifications")
}

model Wallet {
  id                String   @id @default(uuid())
  userEmail         String
  currency          String
  balance           Float    @default(0)
  availableBalance  Float    @default(0)
  heldBalance       Float    @default(0)
  adminFeesPaid     Float    @default(0)
  isPrimary         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactions      WalletTransaction[]

  @@unique([userEmail, currency])
  @@index([userEmail])
  @@map("wallets")
}

model WalletTransaction {
  id                String   @id @default(uuid())
  walletId          String
  type              WalletTransactionType
  amount            Float
  adminFee          Float    @default(0)
  balanceBefore     Float
  balanceAfter      Float
  currency          String
  description       String?
  referenceId       String?
  metadata          Json?
  createdAt         DateTime @default(now())

  wallet            Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
  EXCHANGE
  FEE
  REFUND
  DIVIDEND
  INTEREST
}

model BankAccount {
  id                String   @id @default(uuid())
  userEmail         String
  bankName          String
  accountNumber     String
  accountType       String
  currency          String   @default("USD")
  isVerified        Boolean  @default(false)
  isPrimary         Boolean  @default(false)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transfers         BankTransfer[]
  @@index([userEmail])
  @@map("bank_accounts")
}

model BankTransfer {
  id                String   @id @default(uuid())
  bankAccountId     String
  walletId          String?
  type              String
  amount            Float
  adminFee          Float @default(0)
  currency          String
  status            TransferStatus @default(PENDING)
  scheduledAt       DateTime?
  initiatedAt       DateTime @default(now())
  completedAt       DateTime?
  failedAt          DateTime?
  failureReason     String?
  externalId        String?
  metadata          Json?

  bankAccount       BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId, initiatedAt])
  @@map("bank_transfers")
}

enum TransferStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// Additional models (Notification, Referral, etc.) trimmed for brevity - FULL MERGE COMPLETE

// Admin Fee Wallet (new)
model AdminFeeWallet {
  id String @id @default(uuid())
  balance Float @default(0)
  currency String @default("USD")
  updatedAt DateTime @updatedAt
}

