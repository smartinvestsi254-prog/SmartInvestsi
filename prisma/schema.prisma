// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider  = "prisma-client-js"
  engineType = "binary"  // v7: explicit for serverless compat
}

datasource db {
  provider = "postgresql"
}

// ... (existing models unchanged)

model Product {
  id          String   @id @default(cuid())
  title       String
  description String?
  price       Float
  category    String
  inventory   Int?
  status      String   @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]

  @@index([category])
  @@index([status])
}

model Order {
  id              String       @id @default(cuid())
  userEmail       String
  user            User         @relation(fields: [userEmail], references: [email])
  productId       String
  product         Product      @relation(fields: [productId], references: [id])
  quantity        Int
  totalAmount     Float
  status          String       @default("PENDING_PAYMENT") // PENDING_PAYMENT | PAID | SHIPPED | DELIVERED | CANCELLED | FLAGGED_FRAUD
  shippingAddress Json?
  trackingNumber  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userEmail])
  @@index([status])
  @@index([productId])
}

// Add marketplace features to FEATURES
// Update existing User model if needed (already extended)

model Partnership {
  id         String   @id @default(cuid())
  partnerName String
  apiKey     String   @unique // Encrypted
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())

  @@index([status])
}

// Existing models below (User, Portfolio, etc. unchanged for brevity)
model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  name                String?
  role                Role           @default(USER)
  termsAcceptedAt     DateTime?
  emailVerifiedAt     DateTime?
  failedLoginAttempts Int            @default(0)
  isBanned            Boolean        @default(false)
  twoFactorSecret     String?
  lastFailedLogin     DateTime?
  subscriptionTier    String?        @default("FREE")
  accounts            BankAccount[]
  assets              AssetHolding[]
  transactions        Transaction[]
  subscriptions       Subscription[]
  marketplaceOrders   Order[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  payments            Payment[]

  @@index([email])
  @@index([isBanned])
}

// Trading &amp; Crypto Models (Phase 2)

model TradingOrder {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  symbol         String   // BTC/USDT
  side           String   // buy/sell
  type           String   // market/limit
  quantity       Float
  price          Float?
  status         String   @default("pending") // pending/filled/cancelled
  txHash         String?
  exchange       String?  // binance/testnet
  createdAt      DateTime @default(now())
  filledAt       DateTime?

  @@index([userId])
  @@index([status])
  @@index([symbol])
}

model TradingPosition {
  id              String  @id @default(cuid())
  userId          String
  user            User    @relation(fields: [userId], references: [id])
  symbol          String
  quantity        Float
  avgPrice        Float
  currentPrice    Float
  unrealizedPnL   Float
  exchange        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, symbol])
  @@index([userId])
}

model CryptoWallet {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  chain       String   // ethereum/polygon
  address     String   @unique
  privateKey  String?  // Encrypted in prod
  balance     Json?    // { native: "0.1", tokens: [...] }
  createdAt   DateTime @default(now())

  @@unique([userId, chain])
  @@index([userId])
}

model PaymentIntent {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  provider      String   // mpesa/paypal/crypto
  amount        Float
  currency      String
  status        String   @default("pending")
  providerId    String?  // MpesaReceiptNumber etc.
  txHash        String?
  callbackData  Json?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([providerId])
}

// Compliance stubs
model KycVerification {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  status      String   @default("pending") // pending/approved/rejected
  documents   Json[]
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([status])
}

// ... (rest of existing models unchanged - Portfolio, Holding, etc.)

enum Role {
  USER
  ADMIN
}

