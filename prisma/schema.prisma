// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider  = "prisma-client-js"
  engineType = "binary"  // v7: explicit for serverless compat
}

datasource db {
  provider = "postgresql"
}

// ... (existing models unchanged)

model Product {
  id          String   @id @default(cuid())
  title       String
  description String?
  price       Float
  category    String
  inventory   Int?
  status      String   @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]

  @@index([category])
  @@index([status])
}

model Order {
  id              String       @id @default(cuid())
  userEmail       String
  user            User         @relation(fields: [userEmail], references: [email])
  productId       String
  product         Product      @relation(fields: [productId], references: [id])
  quantity        Int
  totalAmount     Float
  status          String       @default("PENDING_PAYMENT") // PENDING_PAYMENT | PAID | SHIPPED | DELIVERED | CANCELLED | FLAGGED_FRAUD
  shippingAddress Json?
  trackingNumber  String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userEmail])
  @@index([status])
  @@index([productId])
}

// Add marketplace features to FEATURES
// Update existing User model if needed (already extended)

model Partnership {
  id         String   @id @default(cuid())
  partnerName String
  apiKey     String   @unique // Encrypted
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())

  @@index([status])
}

// Existing models below (User, Portfolio, etc. unchanged for brevity)
model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  name                String?
  role                Role           @default(USER)
  termsAcceptedAt     DateTime?
  emailVerifiedAt     DateTime?
  failedLoginAttempts Int            @default(0)
  isBanned            Boolean        @default(false)
  twoFactorSecret     String?
  lastFailedLogin     DateTime?
  subscriptionTier    String?        @default("FREE")
  accounts            BankAccount[]
  assets              AssetHolding[]
  transactions        Transaction[]
  subscriptions       Subscription[]
  marketplaceOrders   Order[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  payments            Payment[]

  @@index([email])
  @@index([isBanned])
}

// ... (rest of existing models unchanged - Portfolio, Holding, etc.)

enum Role {
  USER
  ADMIN
}

