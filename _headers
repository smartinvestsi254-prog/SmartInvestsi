# SmartInvest Security Headers and CORS Configuration
# Netlify _headers file - applies to all routes unless overridden

# Global security headers for all routes
/*
  # Security Headers
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

  # HTTPS and HSTS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Content Security Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://www.chatbase.co https://js.stripe.com https://www.paypal.com https://www.paypalobjects.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https://api.stripe.com https://api.paypal.com https://www.chatbase.co https://smartinvestsi.netlify.app; frame-src https://js.stripe.com https://www.paypal.com https://www.chatbase.co

# API routes - restricted CORS allowlist
/api/*
  # CORS Headers - Allowlist instead of wildcard
  Access-Control-Allow-Origin: https://smartinvestsi.netlify.app
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization, X-Requested-With
  Access-Control-Allow-Credentials: false
  Access-Control-Max-Age: 86400

  # Additional API security
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff

# Banking API specific headers
/api/banking/*
  # Enhanced security for financial operations
  Access-Control-Allow-Origin: https://smartinvestsi.netlify.app
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization, X-API-Key
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Payment API specific headers
/api/payments/*
  Access-Control-Allow-Origin: https://smartinvestsi.netlify.app
  Access-Control-Allow-Methods: GET, POST, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization, Stripe-Signature
  Cache-Control: no-cache, no-store, must-revalidate

# Trading API specific headers
/api/trading/*
  Access-Control-Allow-Origin: https://smartinvestsi.netlify.app
  Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization
  Cache-Control: no-cache, no-store, must-revalidate

# Market data API headers
/api/market/*
  Access-Control-Allow-Origin: https://smartinvestsi.netlify.app
  Access-Control-Allow-Methods: GET, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization
  Cache-Control: public, max-age=300, s-maxage=300

# Chat API headers (external service)
/api/chat/*
  Access-Control-Allow-Origin: https://smartinvestsi.netlify.app
  Access-Control-Allow-Methods: GET, POST, OPTIONS
  Access-Control-Allow-Headers: Content-Type, Authorization

# Static assets - optimized caching
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# Images - moderate caching
/*.png
  Cache-Control: public, max-age=86400

/*.jpg
  Cache-Control: public, max-age=86400

/*.svg
  Cache-Control: public, max-age=86400

# HTML pages - short cache
/*.html
  Cache-Control: public, max-age=3600

# Admin routes - no caching, enhanced security
/admin/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

