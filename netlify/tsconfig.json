{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "../dist/netlify",
    "rootDir": "./",
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": false,
    "allowSyntheticDefaultImports": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
