{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "installCommand": "npm install --production=false",
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000"
  },
  "envObjects": {
    "production": {
      "NODE_ENV": "production"
    },
    "preview": {
      "NODE_ENV": "production"
    }
  },
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "builds": [
    {
      "src": "dist/server.js",
      "use": "@vercel/node",
      "config": {
        "nodejs": "20.11.0"
      }
    },
    {
      "src": "dist/netlify/**/*.js",
      "use": "@vercel/node",
      "config": {
        "nodejs": "20.11.0"
      }
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static",
      "config": {
        "maxAge": 3600
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/dist/server.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/pochi/(.*)",
      "dest": "/dist/server.js",
      "methods": ["POST", "GET"]
    },
    {
      "src": "/health",
      "dest": "/dist/server.js"
    },
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*\\.(?:css|js|ico|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot)$)",
      "dest": "/$1"
    },
    {
      "src": "^/(?!api/).*\\.html$",
      "dest": "/$0",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server.js"
    }
  ]
}
