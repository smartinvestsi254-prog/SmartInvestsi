# SmartInvest Environment Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
NODE_ENV=development
PORT=3000
APP_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
LOG_LEVEL=info

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_change_in_production
JWT_EXPIRES=12h
ENFORCE_STRICT_JWT=true
SESSION_SECRET=your_super_secret_session_key_minimum_32_characters_long_change_in_production
DISCOVERY_URL=https://yourdomain.com/.well-known/openid-configuration
KEY_ID=your_key_id_from_auth_provider
ISSUER=https://yourdomain.com
AUDIENCE=your_audience_from_auth_provider
LEGACY_JWT_SECRET=your_legacy_jwt_secret_for_token_rotation

# Admin Authentication
ADMIN_USER=*************
ADMIN_PASSWORD=*******-*****
ADMIN_EMAIL=your_admin_email
ADMIN_ACCOUNT_ID=SmartInvest_1

# M-Pesa Daraja API Configuration
# Get credentials from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here
MPESA_ENV=production
MPESA_NUMBER=your_business_shortcode
MPESA_SHORTCODE=your_business_shortcode
MPESA_PAYBILL=your_paybill_number
MPESA_PASSKEY=your_mpesa_passkey_from_safaricom
MPESA_POCHI_NAME=SmartInvest
MPESA_CALLBACK_URL=https://yourdomain.com/api/pochi/callback
MPESA_ACCOUNT_REF=SmartInvest

# KCB Bank Details for Manual Payments
KCB_BANK_NAME=Kenya Commercial Bank
KCB_ACCOUNT_NAME=your_kcb_account_name
KCB_ACCOUNT_NUMBER=your_kcb_account_number
KCB_BRANCH_NAME=your_kcb_branch_name
KCB_BRANCH_CODE=your_kcb_branch_code

# PayPal Configuration (LIVE)
PAYPAL_CLIENT_ID=your_paypal_live_client_id
PAYPAL_CLIENT_SECRET=your_paypal_live_client_secret
PAYPAL_ENV=production
PAYPAL_MODE=production
PAYPAL_RETURN_URL=https://yourdomain.com/paypal/return
PAYPAL_CANCEL_URL=https://yourdomain.com/paypal/cancel
PAYPAL_RECEIVER_EMAIL=delijah5415@gmail.com

# Google Pay Configuration (LIVE)
GOOGLE_PAY_EMAIL=delijah5415@gmail.com
GOOGLE_MERCHANT_ID=your_google_merchant_id
GOOGLE_MERCHANT_NAME=SmartInvest
GOOGLE_MERCHANT_PRIVATE_KEY=your_google_merchant_private_key
GOOGLE_PLAY_PUBLIC_KEY=your_google_play_public_key

# Stripe Live API (Production Only)
STRIPE_LIVE_API_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_LIVE_SECRET_KEY=sk_live_xxxxxxxxxxxxx

# MongoDB Configuration
MONGODB_URl=your_mongodb_connection_string

# Database Configuration (PostgreSQL/Supabase)
DATABASE_URL=your_database_connection_string
DIRECT_URL=your_direct_database_connection_string

# Exchange Rate
EXCHANGE_RATE_KES_USD=0.0065

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@smartinvest.com
EMAIL_FROM_NAME=SmartInvest

# Public Contact Information
# These are displayed on the website contact page and support lines
SUPPORT_EMAIL=support@smartinvestsi.netlify.app
SUPPORT_PHONE=+254114383762

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Crypto Payments (EVM-compatible)
CRYPTO_TREASURY_ADDRESS=0xYourTreasuryAddress
CRYPTO_CHAIN_ID=1
CRYPTO_ASSET_SYMBOL=ETH
CRYPTO_NATIVE_DECIMALS=18
CRYPTO_USD_RATE=3200
CRYPTO_RPC_URL=https://mainnet.infura.io/v3/your_project_id
CRYPTO_REQUIRED_CONFIRMATIONS=2
CRYPTO_PAYMENT_TTL_MINUTES=30

# Marketplace & Payments (LIVE MODE ONLY - NO DEMOS)
ADMIN_EMAIL=smartinvestsi254@gmail.com

# Fraud Detection
FRAUD_CHECK_ENABLED=true
FRAUD_BLOCK_THRESHOLD=70
FRAUD_REVIEW_THRESHOLD=50

# External Integrations
INTEGRATION_REQUEST_APPROVAL_REQUIRED=true
FREE_TIER_MONTHLY_REQUESTS=1000
PREMIUM_TIER_MONTHLY_REQUESTS=100000
PREMIUM_SUBSCRIPTION_COST=10.00
ENTERPRISE_SUBSCRIPTION_COST=20.00
CURRENCY=USD

# Shipping Carriers
SHIPPING_CARRIERS_ENABLED=true
SHIPPING_LABEL_EXPIRY_DAYS=30

# Analytics & Monitoring
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=google_analytics
# Google Analytics Configuration
GA_TRACKING_ID=UA-XXXXXXXXX-X  

# SUPABASE Configuration
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key 
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
SUPABASE_DB_URL=your_supabase_db_connection_string
SUPABASE_DB_USER=your_supabase_db_user
SUPABASE_DB_PASSWORD=your_supabase_db_password
SUPABASE_DB_NAME=your_supabase_db_name
SUPABASE_DB_PORT=5432
SUPABASE_DB_HOST=your_supabase_db_host
ANON_KEY=your_supabase_anon_key
SUPABASE_API_URL=https://your-supabase-url.supabase.co/rest/v1
SUPABASE_REALTIME_URL=wss://your-supabase-url.supabase.co/realtime
SUPABASE_AUTH_URL=https://your-supabase-url.supabase.co/auth/v1
SUPABASE_STORAGE_URL=https://your-supabase-url.supabase.co/storage/v1
SUPABASE_FUNCTIONS_URL=https://your-supabase-url.supabase.co/functions/v1
SUPABASE_DB_SSL=true
SUPABASE_DB_CONNECTION_TIMEOUT=5000
SUPABASE_DB_IDLE_TIMEOUT=10000
SUPABASE_DB_MAX_CONNECTIONS=20
SUPABASE_DB_MIN_CONNECTIONS=0
SUPABASE_DB_POOL_SIZE=10
SUPABASE_DB_MAX_IDLE_TIME=30000
SUPABASE_DB_MAX_LIFETIME=600000
SUPABASE_DB_LOGGING=false
SUPABASE_DB_MIGRATIONS_DIR=./migrations
SUPABASE_DB_SEEDS_DIR=./seeds
SUPABASE_DB_SCRIPTS_DIR=./scripts
SUPABASE_DB_BACKUP_DIR=./backups
SUPABASE_DB_RESTORE_DIR=./restores
SUPABASE_DB_DUMP_DIR=./dumps
SUPABASE_DB_REPLICATION=true
DATABASE_URL=your_supabase_db_connection_string
DIRECT_URL=your_supabase_db_connection_string

