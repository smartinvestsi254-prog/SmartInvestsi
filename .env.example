# SmartInvestsi Complete Environment Configuration
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# ============================================
# 🔐 CRITICAL - Security Keys (Generate fresh!)
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-64-character-jwt-secret-key-generate-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=your-64-character-refresh-secret-key-generate-with-openssl-rand-hex-32
SESSION_SECRET=your-64-character-session-secret-key-generate-with-openssl-rand-hex-32

# ============================================
# 📊 Database Configuration
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/smartinvest?schema=public
DIRECT_URL=postgresql://user:password@localhost:5432/smartinvest
REDIS_URL=redis://localhost:6379

# ============================================
# 🔐 Supabase Configuration
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-keep-secret

# ============================================
# 📧 Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend@yourdomain.com
SMTP_PASS=your-api-key
SMTP_FROM=noreply@smartinvestsi.com
SMTP_FROM_NAME=SmartInvestsi

# ============================================
# 💳 Payment Processing
# ============================================
# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox
PAYPAL_ENV=sandbox
PAYPAL_RETURN_URL=https://yourdomain.com/success
PAYPAL_CANCEL_URL=https://yourdomain.com/cancel

# M-Pesa
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback
MPESA_ACCOUNT_REF=SmartInvestsi

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ============================================
# 🤖 Security & Captcha
# ============================================
HCAPTCHA_SITEKEY=your-hcaptcha-sitekey
HCAPTCHA_SECRET=your-hcaptcha-secret
RECAPTCHA_SECRET_KEY=your-recaptcha-secret

# ============================================
# 🪙 Cryptocurrency Configuration
# ============================================
CRYPTO_OKX_API_KEY=your-okx-api-key
CRYPTO_OKX_API_SECRET=your-okx-api-secret
CRYPTO_OKX_PASSPHRASE=your-okx-passphrase
CRYPTO_ASSET_SYMBOL=BTC,ETH,USDT
CRYPTO_CHAIN_ID=1

# ============================================
# 🎯 External APIs & Services
# ============================================
CHATBASE_API_KEY=your-chatbase-api-key
CHATBASE_BOT_ID=your-chatbase-bot-id
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================
# 🛠️ Application Configuration
# ============================================
NODE_ENV=development
APP_URL=http://localhost:3000
APP_ENV=development
LOG_LEVEL=info
PORT=3000

# ============================================
# 👤 Admin Configuration
# ============================================
ADMIN_USER=admin@smartinvestsi.com
ADMIN_EMAIL=admin@smartinvestsi.com
ADMIN_REG_SECRET=your-admin-registration-secret
ADMIN_FALLBACK_KEY=your-admin-fallback-key

# ============================================
# 🔒 Rate Limiting
# ============================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW=15
RATE_LIMIT_ENABLED=true

# ============================================
# 📞 Support Configuration
# ============================================
SUPPORT_EMAIL=support@smartinvestsi.com
SUPPORT_PHONE=+27111234567

# ============================================
# 🌐 Public Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key

# ============================================
# 🧪 Testing Configuration
# ============================================
TEST_MODE=false
SLOW_REQUEST_THRESHOLD_MS=2000

# ============================================
# 📍 Geolocation & Compliance
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,https://smartinvestsi.netlify.app
ADMIN_IPS=127.0.0.1

# ============================================
# 🔄 Background Job Configuration
# ============================================
EU_CENTRAL_1_QSTASH_TOKEN=your-qstash-token-eu
US_EAST_1_QSTASH_TOKEN=your-qstash-token-us
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================
# 📊 Monitoring & Analytics
# ============================================
ENABLE_MONITORING=true
ENABLE_ANALYTICS=true
ANALYTICS_ID=your-analytics-id

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================
# 🛡️ Security & Anti-Fraud
# ============================================
# CAPTCHA (hCaptcha)
HCAPTCHA_SITE_KEY=your-hcaptcha-site-key
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key

# CORS - comma-separated list of allowed origins
ALLOWED_ORIGINS=https://smartinvestsi.netlify.app,https://www.smartinvestsi.com

# Admin registration secret (required to create admin accounts)
ADMIN_REG_SECRET=your-secure-admin-registration-secret

# CEO account for admin fee routing
CEO_ACCOUNT_ID=your-ceo-account-id

# Slow request monitoring threshold (ms)
SLOW_REQUEST_THRESHOLD_MS=2000

# ============================================
# 🏦 Banking & Finance
# ============================================
ENCRYPTION_KEY=your-encryption-key-32-chars-min
POPIA_COMPLIANT=true
GDPR_COMPLIANT=true
NDPR_COMPLIANT=true
KENYA_DPA_COMPLIANT=true
